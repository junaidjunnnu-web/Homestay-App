{
  "expo": {
    "name": "Homestay App",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8824A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.homestayapp.mobile"
    },
    "android": {
      "package": "com.homestayapp.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#E8824A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "name": "Homestay App",
      "shortName": "Homestay",
      "description": "Manage and book beautiful Indian homestays",
      "themeColor": "#E8824A",
      "backgroundColor": "#FAF6F1"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c594af8f-7b27-4f89-a5f5-3665c751988a"
      }
    },
    "owner": "junaidjunnnu"
  }
}
